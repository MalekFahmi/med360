rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Allow searching caregivers by email
      allow read: if request.auth != null && resource.data.role == 'caregiver';
    }

    // Patients can read/write their own patient data
    match /patients/{patientId} {
      allow read, write: if request.auth != null && request.auth.uid == patientId;

      match /caregivers/{caregiverId} {
        allow read, write: if request.auth != null && (request.auth.uid == patientId || request.auth.uid == caregiverId);
      }

      match /caregiverNotifications/{notificationId} {
        allow read, write: if request.auth != null && request.auth.uid == patientId;
      }
    }

    // Relationships between patients and caregivers
    match /patientCaregivers/{relationshipId} {
      allow read, write: if request.auth != null;
    }

    // Caregiver Inboxes
    match /caregiverInboxes/{caregiverUid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == caregiverUid;
    }
  }
}

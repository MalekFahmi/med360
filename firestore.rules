rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      );
    }

    function currentUserData() {
      return currentUserDoc().data;
    }

    function userExists() {
      return signedIn()
        && exists(
          /databases/$(database)/documents/users/$(request.auth.uid)
        );
    }

    function isPatient() {
      return userExists()
        && currentUserData().role == "patient";
    }

    function isCaregiverUser() {
      return userExists()
        && currentUserData().role == "caregiver";
    }

    function isDoctorUser() {
      return userExists()
        && currentUserData().role == "doctor";
    }

    // Patient ownership is determined by the Firebase Auth UID document.
    function isPatientOwner(patientUid) {
      return signedIn()
        && exists(
          /databases/$(database)/documents/patients/$(patientUid)
        )
        && get(
          /databases/$(database)/documents/patients/$(patientUid)
        ).data.ownerUid == request.auth.uid;
    }

    function isLinkedCaregiver(patientUid) {
      return signedIn()
        && exists(
          /databases/$(database)/documents/patientCaregivers/$(patientUid + "_" + request.auth.uid)
        );
    }

    function isLinkedDoctor(patientUid) {
      return signedIn()
        && exists(
          /databases/$(database)/documents/patientDoctorRelations/$(patientUid + "_" + request.auth.uid)
        );
    }

    function canManagePatient(patientUid) {
      return isPatientOwner(patientUid)
        || isLinkedCaregiver(patientUid)
        || isLinkedDoctor(patientUid);
    }

    match /users/{uid} {
      allow create: if signedIn()
        && request.auth.uid == uid;

      allow read, update: if signedIn()
        && request.auth.uid == uid;

      allow delete: if signedIn()
        && request.auth.uid == uid;

      allow list: if false;
    }

    match /caregiverDirectory/{caregiverUid} {
      allow read, list: if signedIn();

      allow create, update: if signedIn()
        && request.auth.uid == caregiverUid
        && request.resource.data.uid == caregiverUid
        && request.resource.data.role == "caregiver";

      allow delete: if signedIn()
        && request.auth.uid == caregiverUid;
    }

    match /doctorDirectory/{doctorUid} {
      allow read, list: if signedIn();

      allow create, update: if signedIn()
        && request.auth.uid == doctorUid
        && request.resource.data.uid == doctorUid
        && request.resource.data.role == "doctor";

      allow delete: if signedIn()
        && request.auth.uid == doctorUid;
    }

    match /patients/{patientUid} {

      // Allow authenticated users to create their own patient document
      allow create: if signedIn()
        && patientUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid;

      allow create: if isCaregiverUser()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.managedByCaregiver == true;

      // Existing ownership checks
      allow read: if isPatientOwner(patientUid)
        || isLinkedCaregiver(patientUid)
        || isLinkedDoctor(patientUid);

      allow update, delete: if isPatientOwner(patientUid);

      match /caregivers/{caregiverUid} {
        allow read: if isPatientOwner(patientUid)
          || request.auth.uid == caregiverUid;

        allow create, update, delete: if isPatientOwner(patientUid);
      }

      match /caregiverNotifications/{notificationId} {
        allow read: if isPatientOwner(patientUid)
          || isLinkedCaregiver(patientUid);

        allow create, update, delete: if isPatientOwner(patientUid);
      }

      match /doctors/{doctorUid} {
        allow read: if isPatientOwner(patientUid)
          || request.auth.uid == doctorUid;

        allow create, update, delete: if isPatientOwner(patientUid);
      }

      match /medications/{medicationId} {
        allow read, create, update: if canManagePatient(patientUid);
        allow delete: if canManagePatient(patientUid);
      }
    }

    match /userDevices/{uid} {

      allow create, update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.firebaseUid == uid;

      allow read, delete: if signedIn()
        && request.auth.uid == uid;
    }

    match /patientDoses/{doseId} {

      allow read: if isPatientOwner(resource.data.ownerUid)
        || isLinkedCaregiver(resource.data.ownerUid)
        || isLinkedDoctor(resource.data.ownerUid);

      allow create: if isPatientOwner(
        request.resource.data.ownerUid
      );

      allow update, delete: if isPatientOwner(
        resource.data.ownerUid
      );
    }

    match /patientCaregivers/{relationshipId} {

      allow read: if signedIn();

      allow create, update:
        if isPatientOwner(
          request.resource.data.patientUid
        )
        || (
          isCaregiverUser()
          && request.resource.data.caregiverUid == request.auth.uid
        );

      allow delete:
        if isPatientOwner(
          resource.data.patientUid
        )
        || (
          isCaregiverUser()
          && resource.data.caregiverUid == request.auth.uid
        );
    }

    match /patientDoctorRelations/{relationshipId} {
      allow read: if signedIn();

      allow create, update:
        if isPatientOwner(
          request.resource.data.patientUid
        );

      allow delete:
        if isPatientOwner(
          resource.data.patientUid
        );
    }

    match /adherenceEvents/{eventId} {
      allow create: if signedIn();
      allow read: if isPatient()
        || isCaregiverUser()
        || isDoctorUser();
      allow update, delete: if false;
    }

    match /medicationChangeLogs/{eventId} {
      allow create: if signedIn();
      allow read: if isPatient()
        || isCaregiverUser()
        || isDoctorUser();
      allow update, delete: if false;
    }

    match /sharedReports/{reportId} {
      allow create: if isPatient();
      allow read, update: if signedIn()
        && (
          resource.data.recipientId == request.auth.uid
          || resource.data.actorUid == request.auth.uid
        );
      allow delete: if false;
    }

    match /caregiverInboxes/{caregiverUid}/notifications/{notificationId} {

      allow read, update:
        if isCaregiverUser()
        && request.auth.uid == caregiverUid;

      allow create: if signedIn();

      allow delete: if false;
    }

    match /doctorInboxes/{doctorUid}/notifications/{notificationId} {

      allow read, update:
        if isDoctorUser()
        && request.auth.uid == doctorUid;

      allow create: if signedIn();

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

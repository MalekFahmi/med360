rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      );
    }

    function currentUserData() {
      return currentUserDoc().data;
    }

    function userExists() {
      return signedIn()
        && exists(
          /databases/$(database)/documents/users/$(request.auth.uid)
        );
    }

    function isPatient() {
      return userExists()
        && currentUserData().role == "patient";
    }

    function isCaregiverUser() {
      return userExists()
        && currentUserData().role == "caregiver";
    }

    function isDoctorUser() {
      return userExists()
        && currentUserData().role == "doctor";
    }

    // Patient ownership is primarily the Firebase Auth UID path. The ownerUid
    // fallback keeps older patient documents working after migration.
    function isPatientOwner(patientUid) {
      return signedIn()
        && (
          patientUid == request.auth.uid
          || (
            exists(
              /databases/$(database)/documents/patients/$(patientUid)
            )
            && get(
              /databases/$(database)/documents/patients/$(patientUid)
            ).data.ownerUid == request.auth.uid
          )
        );
    }

    function isLinkedCaregiver(patientUid) {
      return signedIn()
        && exists(
          /databases/$(database)/documents/patientCaregivers/$(patientUid + "_" + request.auth.uid)
        );
    }

    function isLinkedDoctor(patientUid) {
      return signedIn()
        && exists(
          /databases/$(database)/documents/patientDoctorRelations/$(patientUid + "_" + request.auth.uid)
        );
    }

    function canManagePatient(patientUid) {
      return isPatientOwner(patientUid)
        || isLinkedCaregiver(patientUid)
        || isLinkedDoctor(patientUid);
    }

    match /users/{uid} {
      allow create: if signedIn()
        && (
          request.auth.uid == uid
          || (
            isCaregiverUser()
            && request.resource.data.role == "patient"
            && request.resource.data.createdByCaregiverUid == request.auth.uid
          )
        );

      allow read: if signedIn()
        && (
          request.auth.uid == uid
          || (
            (isDoctorUser() || isCaregiverUser())
            && resource.data.role == "patient"
          )
        );

      allow list: if isDoctorUser() || isCaregiverUser();

      allow update: if signedIn()
        && request.auth.uid == uid;

      allow delete: if signedIn()
        && request.auth.uid == uid;
    }

    match /caregiverDirectory/{caregiverUid} {
      allow read, list: if signedIn();

      allow create, update: if signedIn()
        && request.auth.uid == caregiverUid
        && request.resource.data.uid == caregiverUid
        && request.resource.data.role == "caregiver";

      allow delete: if signedIn()
        && request.auth.uid == caregiverUid;
    }

    match /doctorDirectory/{doctorUid} {
      allow read, list: if signedIn();

      allow create, update: if signedIn()
        && request.auth.uid == doctorUid
        && request.resource.data.uid == doctorUid
        && request.resource.data.role == "doctor";

      allow delete: if signedIn()
        && request.auth.uid == doctorUid;
    }

    match /patientDirectory/{patientUid} {
      allow read, list: if isDoctorUser() || isCaregiverUser();

      allow create, update: if request.resource.data.patientUid == patientUid
        && (
          isPatientOwner(patientUid)
          || (
            isCaregiverUser()
            && request.resource.data.createdByCaregiverUid == request.auth.uid
          )
        );

      allow delete: if isPatientOwner(patientUid);
    }

    match /patients/{patientUid} {

      // Allow authenticated users to create their own patient document
      allow create: if signedIn()
        && patientUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid;

      allow create: if isCaregiverUser()
        && request.resource.data.ownerUid == patientUid
        && request.resource.data.createdByCaregiverUid == request.auth.uid;

      // Existing ownership checks
      allow read: if isPatientOwner(patientUid)
        || isLinkedCaregiver(patientUid)
        || isLinkedDoctor(patientUid);

      allow update, delete: if isPatientOwner(patientUid);

      match /caregivers/{caregiverUid} {
        allow read: if isPatientOwner(patientUid)
          || request.auth.uid == caregiverUid;

        allow create, update: if isPatientOwner(patientUid)
          || (
            isCaregiverUser()
            && request.auth.uid == caregiverUid
            && request.resource.data.patientUid == patientUid
          );

        allow delete: if isPatientOwner(patientUid)
          || (
            isCaregiverUser()
            && request.auth.uid == caregiverUid
          );
      }

      match /caregiverNotifications/{notificationId} {
        allow read: if isPatientOwner(patientUid)
          || isLinkedCaregiver(patientUid);

        allow create, update, delete: if isPatientOwner(patientUid);
      }

      match /doctors/{doctorUid} {
        allow read: if (signedIn() && patientUid == request.auth.uid)
          || isPatientOwner(patientUid)
          || request.auth.uid == doctorUid;

        allow create, update: if isPatientOwner(patientUid)
          || (
            isDoctorUser()
            && request.auth.uid == doctorUid
            && request.resource.data.patientUid == patientUid
          );

        allow delete: if isPatientOwner(patientUid)
          || (
            isDoctorUser()
            && request.auth.uid == doctorUid
          );
      }

      match /medications/{medicationId} {
        allow read, create, update: if canManagePatient(patientUid);
        allow delete: if canManagePatient(patientUid);
      }
    }

    match /userDevices/{uid} {

      allow create, update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.firebaseUid == uid;

      allow read, delete: if signedIn()
        && request.auth.uid == uid;
    }

    match /patientDoses/{doseId} {

      allow read: if isPatientOwner(resource.data.ownerUid)
        || isLinkedCaregiver(resource.data.ownerUid)
        || isLinkedDoctor(resource.data.ownerUid);

      allow create: if isPatientOwner(
        request.resource.data.ownerUid
      );

      allow update, delete: if isPatientOwner(
        resource.data.ownerUid
      );
    }

    match /patientCaregivers/{relationshipId} {

      allow read: if isPatientOwner(resource.data.patientUid)
        || request.auth.uid == resource.data.caregiverUid
        || isLinkedDoctor(resource.data.patientUid);

      allow create, update:
        if isPatientOwner(
          request.resource.data.patientUid
        )
        || (
          isCaregiverUser()
          && request.resource.data.caregiverUid == request.auth.uid
        );

      allow delete:
        if isPatientOwner(
          resource.data.patientUid
        )
        || (
          isCaregiverUser()
          && resource.data.caregiverUid == request.auth.uid
        );
    }

    match /patientDoctorRelations/{relationshipId} {
      allow read: if isPatientOwner(resource.data.patientUid)
        || request.auth.uid == resource.data.doctorId
        || isLinkedCaregiver(resource.data.patientUid);

      allow create, update:
        if isPatientOwner(
          request.resource.data.patientUid
        )
        || (
          isDoctorUser()
          && request.resource.data.doctorId == request.auth.uid
        );

      allow delete:
        if isPatientOwner(
          resource.data.patientUid
        )
        || (
          isDoctorUser()
          && resource.data.doctorId == request.auth.uid
        );
    }

    match /adherenceEvents/{eventId} {
      allow create: if signedIn()
        && request.resource.data.actorUid == request.auth.uid
        && (
          (
            request.resource.data.patientUid is string
            && canManagePatient(request.resource.data.patientUid)
          )
          || (
            request.resource.data.eventCategory == "userEngagement"
            && !("patientId" in request.resource.data)
            && !("patientUid" in request.resource.data)
          )
        );
      allow read: if signedIn()
        && (
          resource.data.actorUid == request.auth.uid
          || (
            resource.data.patientUid is string
            && canManagePatient(resource.data.patientUid)
          )
        );
      allow update, delete: if false;
    }

    match /medicationChangeLogs/{eventId} {
      allow create: if signedIn()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.patientUid is string
        && canManagePatient(request.resource.data.patientUid);
      allow read: if signedIn()
        && resource.data.patientUid is string
        && canManagePatient(resource.data.patientUid);
      allow update, delete: if false;
    }

    match /sharedReports/{reportId} {
      allow create: if isPatient();
      allow read, update: if signedIn()
        && (
          resource.data.recipientId == request.auth.uid
          || resource.data.actorUid == request.auth.uid
        );
      allow delete: if false;
    }

    match /caregiverInboxes/{caregiverUid}/notifications/{notificationId} {

      allow read, update:
        if isCaregiverUser()
        && request.auth.uid == caregiverUid;

      allow create: if signedIn()
        && request.resource.data.patientUid is string
        && request.resource.data.recipientId == caregiverUid
        && isPatientOwner(request.resource.data.patientUid);

      allow delete: if false;
    }

    match /doctorInboxes/{doctorUid}/notifications/{notificationId} {

      allow read, update:
        if isDoctorUser()
        && request.auth.uid == doctorUid;

      allow create: if signedIn()
        && request.resource.data.patientUid is string
        && request.resource.data.recipientId == doctorUid
        && isPatientOwner(request.resource.data.patientUid);

      allow delete: if false;
    }

    match /patientInboxes/{patientUid}/notifications/{notificationId} {

      allow read, update:
        if isPatientOwner(patientUid);

      allow create: if signedIn()
        && request.resource.data.patientUid == patientUid
        && request.resource.data.recipientId == patientUid
        && canManagePatient(patientUid);

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

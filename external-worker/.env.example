PORT=8080
POLL_INTERVAL_SECONDS=60
AUTO_MISS_DELAY_MINUTES=5
MAX_DOSES_PER_POLL=100
MAX_NOTIFICATIONS_PER_POLL=100

# Option 1: path to a Firebase service account JSON file on the server.
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/firebase-service-account.json

# Option 2: base64-encoded service account JSON. Use this when the host
# does not support secret files.
# FIREBASE_SERVICE_ACCOUNT_BASE64=eyJ0eXAiOi...
